# .env.prod.example — Production deployment
# Copy to .env.prod and fill in your values.
# Never commit .env.prod to version control.
#
# Usage:
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml \
#     --env-file .env.prod --profile observability up -d

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_DB=flint_fhir
POSTGRES_USER=flint_fhir
# Generate: openssl rand -hex 16
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ── Security ──────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_GENERATED_SECRET
ENABLE_AUTH=false

# API key required on X-API-Key header for /admin/* and /ai/* endpoints.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_API_KEY=REPLACE_WITH_STRONG_API_KEY

# Built-in JWT (Option C) — used when ENABLE_AUTH=true and OIDC_ISSUER_URL is unset.
# Obtain a token: POST /auth/token  (form fields: username, password)
AUTH_USERNAME=admin
AUTH_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
AUTH_TOKEN_EXPIRE_MINUTES=60

# External OIDC (Option A) — set this to use Keycloak, Auth0, Azure AD, etc.
# When set, /auth/token is disabled and clients must obtain tokens from the OIDC provider.
# Example: https://keycloak.yourorg.com/realms/phts
OIDC_ISSUER_URL=

# Public base URL — used in SMART discovery document (GET /auth/.well-known/smart-configuration)
BASE_URL=https://YOUR_DOMAIN_HERE

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash)
CORS_ORIGINS=https://YOUR_DOMAIN_HERE,https://www.YOUR_DOMAIN_HERE

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Infrastructure ────────────────────────────────────────────────────────────
# These default to Docker Compose service names — only override for external services.
ELASTICSEARCH_URL=http://elasticsearch:9200
REDIS_URL=redis://redis:6379
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ── Observability ─────────────────────────────────────────────────────────────
GRAFANA_USER=admin
# Generate: openssl rand -hex 12
GRAFANA_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
PGADMIN_EMAIL=admin@YOUR_DOMAIN_HERE
PGADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ── AI Provider ───────────────────────────────────────────────────────────────
# Choose: anthropic | openai | gemini
AI_PROVIDER=anthropic

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# ── External Code Systems ─────────────────────────────────────────────────────
# VSAC/UMLS: free account at https://uts.nlm.nih.gov/uts/signup-login
UMLS_API_KEY=

# LOINC: legacy — NLM ClinicalTables is now the default (no credentials needed)
LOINC_USERNAME=
LOINC_PASSWORD=
