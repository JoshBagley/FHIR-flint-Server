# .env.example — Local development
# Copy to .env and fill in your values.
# Never commit .env to version control.

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_DB=flint_fhir
POSTGRES_USER=flint_fhir
POSTGRES_PASSWORD=flint_dev_password

# ── Security ──────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-secret-key-in-production
ENABLE_AUTH=false

# API key required on X-API-Key header for /admin/* and /ai/* endpoints.
# Leave empty to disable (dev only). Generate: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_API_KEY=

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost:5173

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=debug

# ── Infrastructure ────────────────────────────────────────────────────────────
# These default to the Docker Compose service names — only override if your
# topology differs (e.g. external Elasticsearch cluster or Redis instance).
ELASTICSEARCH_URL=http://elasticsearch:9200
REDIS_URL=redis://redis:6379
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ── Observability ─────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin

# ── AI Provider ───────────────────────────────────────────────────────────────
# Choose: anthropic | openai | gemini
AI_PROVIDER=anthropic

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# ── External Code Systems ─────────────────────────────────────────────────────
# VSAC/UMLS: free account at https://uts.nlm.nih.gov/uts/signup-login
UMLS_API_KEY=

# LOINC: legacy — NLM ClinicalTables is now the default (no credentials needed)
LOINC_USERNAME=
LOINC_PASSWORD=
