{
  "info": {
    "name": "Flint FHIR Server",
    "description": "Complete API collection for the Flint FHIR R4 server. Set the `base_url` variable to your server (default: http://localhost).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost", "type": "string" },
    { "key": "patient_id", "value": "", "type": "string" },
    { "key": "observation_id", "value": "", "type": "string" },
    { "key": "condition_id", "value": "", "type": "string" },
    { "key": "encounter_id", "value": "", "type": "string" },
    { "key": "organization_id", "value": "", "type": "string" },
    { "key": "valueset_id", "value": "", "type": "string" },
    { "key": "codesystem_id", "value": "", "type": "string" },
    { "key": "conceptmap_id", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Health & Metadata",
      "item": [
        {
          "name": "GET /ready — health check",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/ready"
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));"
          ]}}]
        },
        {
          "name": "GET /metadata — CapabilityStatement",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/fhir+json" }],
            "url": "{{base_url}}/metadata"
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const b = pm.response.json();",
            "pm.test('CapabilityStatement', () => pm.expect(b.resourceType).to.equal('CapabilityStatement'));",
            "pm.test('FHIR 4.0.1', () => pm.expect(b.fhirVersion).to.equal('4.0.1'));"
          ]}}]
        },
        {
          "name": "GET /stats — server stats",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/$stats"
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));"
          ]}}]
        }
      ]
    },
    {
      "name": "Patient",
      "item": [
        {
          "name": "POST /Patient — create",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/fhir+json" }],
            "url": "{{base_url}}/Patient",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"resourceType\": \"Patient\",\n  \"name\": [{\"family\": \"Smith\", \"given\": [\"John\"]}],\n  \"gender\": \"male\",\n  \"birthDate\": \"1990-01-15\",\n  \"identifier\": [{\"system\": \"http://example.org/mrn\", \"value\": \"MRN001\"}]\n}"
            }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "const b = pm.response.json();",
            "pm.test('Has id', () => pm.expect(b.id).to.be.a('string'));",
            "pm.test('Has ETag', () => pm.expect(pm.response.headers.get('ETag')).to.include('W/\"'));",
            "pm.environment.set('patient_id', b.id);"
          ]}}]
        },
        {
          "name": "GET /Patient/{id} — read",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/Patient/{{patient_id}}"
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Correct id', () => pm.expect(pm.response.json().id).to.equal(pm.environment.get('patient_id')));"
          ]}}]
        },
        {
          "name": "PUT /Patient/{id} — update",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/fhir+json" }],
            "url": "{{base_url}}/Patient/{{patient_id}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"resourceType\": \"Patient\",\n  \"name\": [{\"family\": \"Smith\", \"given\": [\"John\"]}],\n  \"gender\": \"male\",\n  \"birthDate\": \"1990-01-15\",\n  \"active\": true\n}"
            }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Active flag set', () => pm.expect(pm.response.json().active).to.equal(true));"
          ]}}]
        },
        {
          "name": "GET /Patient — search by family",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/Patient?family=Smith&_count=20",
              "query": [
                { "key": "family", "value": "Smith" },
                { "key": "_count", "value": "20" }
              ]
            }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const b = pm.response.json();",
            "pm.test('Bundle searchset', () => pm.expect(b.type).to.equal('searchset'));",
            "pm.test('Has results', () => pm.expect(b.total).to.be.above(0));"
          ]}}]
        },
        {
          "name": "GET /Patient/{id}/_history — history",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/Patient/{{patient_id}}/_history"
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('History bundle', () => pm.expect(pm.response.json().type).to.equal('history'));"
          ]}}]
        },
        {
          "name": "GET /Patient/{id}/_history/1 — versioned read",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/Patient/{{patient_id}}/_history/1"
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));"
          ]}}]
        },
        {
          "name": "GET /Patient/{id}/$audit — audit log",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/Patient/{{patient_id}}/$audit"
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));"
          ]}}]
        },
        {
          "name": "DELETE /Patient/{id} — delete",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/Patient/{{patient_id}}"
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 204', () => pm.response.to.have.status(204));"
          ]}}]
        }
      ]
    },
