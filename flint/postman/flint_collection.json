    {
      "name": "Bundle",
      "item": [
        {
          "name": "POST / — batch (create 2 patients)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/fhir+json" }],
            "url": "{{base_url}}/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"resourceType\": \"Bundle\",\n  \"type\": \"batch\",\n  \"entry\": [\n    {\n      \"resource\": {\"resourceType\": \"Patient\", \"name\": [{\"family\": \"Batch\", \"given\": [\"One\"]}], \"gender\": \"male\"},\n      \"request\": {\"method\": \"POST\", \"url\": \"Patient\"}\n    },\n    {\n      \"resource\": {\"resourceType\": \"Patient\", \"name\": [{\"family\": \"Batch\", \"given\": [\"Two\"]}], \"gender\": \"female\"},\n      \"request\": {\"method\": \"POST\", \"url\": \"Patient\"}\n    }\n  ]\n}"
            }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const b = pm.response.json();",
            "pm.test('batch-response type', () => pm.expect(b.type).to.equal('batch-response'));",
            "pm.test('2 entries', () => pm.expect(b.total).to.equal(2));",
            "pm.test('All created', () => b.entry.forEach(e => pm.expect(e.response.status).to.equal('201 Created')));"
          ]}}]
        },
        {
          "name": "POST / — transaction with urn:uuid reference",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/fhir+json" }],
            "url": "{{base_url}}/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"resourceType\": \"Bundle\",\n  \"type\": \"transaction\",\n  \"entry\": [\n    {\n      \"fullUrl\": \"urn:uuid:patient-tx\",\n      \"resource\": {\"resourceType\": \"Patient\", \"name\": [{\"family\": \"Transaction\"}]},\n      \"request\": {\"method\": \"POST\", \"url\": \"Patient\"}\n    },\n    {\n      \"resource\": {\n        \"resourceType\": \"Observation\",\n        \"status\": \"final\",\n        \"code\": {\"coding\": [{\"system\": \"http://loinc.org\", \"code\": \"85354-9\"}]},\n        \"subject\": {\"reference\": \"urn:uuid:patient-tx\"}\n      },\n      \"request\": {\"method\": \"POST\", \"url\": \"Observation\"}\n    }\n  ]\n}"
            }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const b = pm.response.json();",
            "pm.test('transaction-response', () => pm.expect(b.type).to.equal('transaction-response'));",
            "pm.test('2 entries', () => pm.expect(b.total).to.equal(2));",
            "const patientRef = b.entry[0].response.location.split('/_history')[0];",
            "pm.test('Reference resolved', () => pm.expect(b.entry[1].resource.subject.reference).to.equal(patientRef));"
          ]}}]
        },
        {
          "name": "POST / — transaction rollback (intentional failure)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/fhir+json" }],
            "url": "{{base_url}}/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"resourceType\": \"Bundle\",\n  \"type\": \"transaction\",\n  \"entry\": [\n    {\n      \"resource\": {\"resourceType\": \"Patient\", \"name\": [{\"family\": \"Phantom\"}]},\n      \"request\": {\"method\": \"POST\", \"url\": \"Patient\"}\n    },\n    {\n      \"resource\": {\"resourceType\": \"Patient\"},\n      \"request\": {\"method\": \"PUT\", \"url\": \"Patient/this-id-does-not-exist\"}\n    }\n  ]\n}"
            }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 400 (rollback)', () => pm.response.to.have.status(400));",
            "pm.test('OperationOutcome', () => pm.expect(pm.response.json().resourceType).to.equal('OperationOutcome'));"
          ]}}]
        }
      ]
    },
