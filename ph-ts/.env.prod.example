# .env.prod.example — Production deployment
# Copy to .env.prod and fill in your values.
# Never commit .env.prod to version control.
#
# Usage:
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml \
#     --env-file .env.prod --profile observability up -d

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_DB=phts
POSTGRES_USER=phts
# Generate: openssl rand -hex 16
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ── Security ──────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_GENERATED_SECRET
ENABLE_AUTH=false

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash)
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Observability ─────────────────────────────────────────────────────────────
GRAFANA_USER=admin
# Generate: openssl rand -hex 12
GRAFANA_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
PGADMIN_EMAIL=admin@your-domain.com
PGADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ── AI Provider ───────────────────────────────────────────────────────────────
# Choose: anthropic | openai | gemini
AI_PROVIDER=anthropic

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── External Code Systems ─────────────────────────────────────────────────────
# VSAC/UMLS: free account at https://uts.nlm.nih.gov/uts/signup-login
UMLS_API_KEY=

# LOINC: legacy — NLM ClinicalTables is now the default (no credentials needed)
LOINC_USERNAME=
LOINC_PASSWORD=
