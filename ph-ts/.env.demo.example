# .env.demo.example — Demo / staging deployment
# Copy to .env.demo and fill in your values.
# Never commit .env.demo to version control.
#
# Usage:
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml \
#     --env-file .env.demo up -d

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_DB=phts
POSTGRES_USER=phts
# Use a strong random password — e.g. openssl rand -hex 16
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ── Security ──────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_GENERATED_SECRET
ENABLE_AUTH=false

# ── CORS ──────────────────────────────────────────────────────────────────────
# Replace with your actual demo domain
CORS_ORIGINS=https://your-demo-domain.com

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Observability ─────────────────────────────────────────────────────────────
GRAFANA_USER=admin
# Use a strong password — Grafana will be publicly reachable on port 3001 if exposed
GRAFANA_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
PGADMIN_EMAIL=admin@your-demo-domain.com
PGADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ── AI Provider ───────────────────────────────────────────────────────────────
# Choose: anthropic | openai | gemini
AI_PROVIDER=anthropic

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── External Code Systems ─────────────────────────────────────────────────────
UMLS_API_KEY=
LOINC_USERNAME=
LOINC_PASSWORD=
