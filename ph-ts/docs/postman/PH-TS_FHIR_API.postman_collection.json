          }
        },
        {
          "name": "Get ConceptMap by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/fhir+json" }],
            "url": { "raw": "{{base_url}}/ConceptMap/{{cm_id}}", "host": ["{{base_url}}"], "path": ["ConceptMap","{{cm_id}}"] }
          }
        },
        {
          "name": "$translate — code via ConceptMap",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/fhir+json" }],
            "url": {
              "raw": "{{base_url}}/ConceptMap/$translate?system=http://terminology.hl7.org/CodeSystem/v2-0001&code=M",
              "host": ["{{base_url}}"], "path": ["ConceptMap","$translate"],
              "query": [
                { "key": "system", "value": "http://terminology.hl7.org/CodeSystem/v2-0001" },
                { "key": "code",   "value": "M" }
              ]
            }
          }
        },
        {
          "name": "Create ConceptMap",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/fhir+json" },
              { "key": "Accept",       "value": "application/fhir+json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"resourceType\": \"ConceptMap\",\n  \"name\": \"PHTS_TestMap\",\n  \"title\": \"Test HL7 v2 Sex to FHIR AdministrativeGender\",\n  \"status\": \"draft\",\n  \"group\": [\n    {\n      \"source\": \"http://terminology.hl7.org/CodeSystem/v2-0001\",\n      \"target\": \"http://hl7.org/fhir/administrative-gender\",\n      \"element\": [\n        { \"code\": \"M\", \"display\": \"Male\",   \"target\": [{ \"code\": \"male\",   \"display\": \"Male\",   \"equivalence\": \"equivalent\" }] },\n        { \"code\": \"F\", \"display\": \"Female\", \"target\": [{ \"code\": \"female\", \"display\": \"Female\", \"equivalence\": \"equivalent\" }] },\n        { \"code\": \"U\", \"display\": \"Unknown\",\"target\": [{ \"code\": \"unknown\",\"display\": \"Unknown\",\"equivalence\": \"equivalent\" }] }\n      ]\n    }\n  ]\n}"
            },
            "url": { "raw": "{{base_url}}/ConceptMap", "host": ["{{base_url}}"], "path": ["ConceptMap"] }
          }
        }
      ]
    },

