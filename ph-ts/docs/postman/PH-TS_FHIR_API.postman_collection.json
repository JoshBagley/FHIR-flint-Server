{
  "info": {
    "name": "PH-TS FHIR Terminology Server",
    "description": "Complete API test collection for the Public Health FHIR R4 Terminology Server.\n\nSwitch between **PH-TS Local** and **PH-TS Production** environments to target the appropriate server.\n\nEndpoints requiring auth pass `X-API-Key: {{api_key}}` — set this in the active environment.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [],
  "auth": {
    "type": "apikey",
    "apikey": [
      { "key": "key",   "value": "X-API-Key",    "type": "string" },
      { "key": "value", "value": "{{api_key}}",   "type": "string" },
      { "key": "in",    "value": "header",         "type": "string" }
    ]
  },
  "item": [

    {
      "name": "01 · Server",
      "description": "Conformance, health, and statistics endpoints.",
      "item": [
        {
          "name": "CapabilityStatement (metadata)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/fhir+json" }],
            "url": { "raw": "{{base_url}}/metadata", "host": ["{{base_url}}"], "path": ["metadata"] }
          }
        },
        {
          "name": "Health check",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/health", "host": ["{{base_url}}"], "path": ["health"] }
          }
        },
        {
          "name": "Analytics summary",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/analytics/summary", "host": ["{{base_url}}"], "path": ["analytics","summary"] }
          }
        },
        {
          "name": "$stats (resource counts by system)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/fhir+json" }],
            "url": { "raw": "{{base_url}}/$stats", "host": ["{{base_url}}"], "path": ["$stats"] }
          }
        }
      ]
    },

    {
      "name": "02 · ValueSet — CRUD",
      "description": "Create, read, update, delete, and history for ValueSet resources.",
      "item": [
        {
          "name": "List ValueSets (summary)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/fhir+json" }],
            "url": {
              "raw": "{{base_url}}/ValueSet?_summary=true&_count=20",
              "host": ["{{base_url}}"], "path": ["ValueSet"],
              "query": [
                { "key": "_summary", "value": "true" },
                { "key": "_count",   "value": "20" }
              ]
            }
          }
        },
        {
          "name": "List ValueSets — filter by name",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/fhir+json" }],
            "url": {
              "raw": "{{base_url}}/ValueSet?name=specimen&_summary=true",
              "host": ["{{base_url}}"], "path": ["ValueSet"],
              "query": [
                { "key": "name",     "value": "specimen" },
                { "key": "_summary", "value": "true" }
              ]
            }
          }
        },
        {
          "name": "List ValueSets — filter by status",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/fhir+json" }],
            "url": {
              "raw": "{{base_url}}/ValueSet?status=active&_summary=true",
              "host": ["{{base_url}}"], "path": ["ValueSet"],
              "query": [
                { "key": "status",   "value": "active" },
                { "key": "_summary", "value": "true" }
              ]
            }
          }
        },
        {
          "name": "List ValueSets — filter by source (PHIN VADS)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/fhir+json" }],
            "url": {
              "raw": "{{base_url}}/ValueSet?source=phinvads&_summary=true",
              "host": ["{{base_url}}"], "path": ["ValueSet"],
              "query": [
                { "key": "source",   "value": "phinvads" },
                { "key": "_summary", "value": "true" }
              ]
            }
          }
        },
        {
          "name": "List ValueSets — filter by disease view",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/fhir+json" }],
            "url": {
              "raw": "{{base_url}}/ValueSet?context-value-code=covid-19-case-notification&_summary=true",
              "host": ["{{base_url}}"], "path": ["ValueSet"],
              "query": [
                { "key": "context-value-code", "value": "covid-19-case-notification" },
                { "key": "_summary",           "value": "true" }
              ]
            }
          }
        },
        {
          "name": "List ValueSets — by identifier (OID)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/fhir+json" }],
            "url": {
              "raw": "{{base_url}}/ValueSet?identifier=2.16.840.1.114222.4.11.7328&_summary=true",
              "host": ["{{base_url}}"], "path": ["ValueSet"],
              "query": [
                { "key": "identifier", "value": "2.16.840.1.114222.4.11.7328" },
                { "key": "_summary",   "value": "true" }
              ]
            }
          }
        },
        {
          "name": "List ValueSets — archived only",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/fhir+json" }],
            "url": {
              "raw": "{{base_url}}/ValueSet?_archived=true&_summary=true",
              "host": ["{{base_url}}"], "path": ["ValueSet"],
              "query": [
                { "key": "_archived", "value": "true" },
                { "key": "_summary",  "value": "true" }
              ]
            }
          }
        },
        {
          "name": "Get ValueSet by ID (full)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/fhir+json" }],
            "url": { "raw": "{{base_url}}/ValueSet/{{vs_id}}", "host": ["{{base_url}}"], "path": ["ValueSet","{{vs_id}}"] }
          }
        },
        {
          "name": "Get ValueSet — version history",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/fhir+json" }],
            "url": { "raw": "{{base_url}}/ValueSet/{{vs_id}}/_history", "host": ["{{base_url}}"], "path": ["ValueSet","{{vs_id}}","_history"] }
          }
        },
        {
          "name": "Get ValueSet — audit log",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/ValueSet/{{vs_id}}/$audit", "host": ["{{base_url}}"], "path": ["ValueSet","{{vs_id}}","$audit"] }
          }
        },
        {
          "name": "Create ValueSet",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/fhir+json" },
              { "key": "Accept",       "value": "application/fhir+json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"resourceType\": \"ValueSet\",\n  \"name\": \"PHTS_TestValueSet\",\n  \"title\": \"PH-TS Test Value Set\",\n  \"status\": \"draft\",\n  \"description\": \"A test value set created via the API.\",\n  \"compose\": {\n    \"include\": [\n      {\n        \"system\": \"http://snomed.info/sct\",\n        \"concept\": [\n          { \"code\": \"119297000\", \"display\": \"Blood specimen\" },\n          { \"code\": \"258450006\", \"display\": \"Cerebrospinal fluid sample\" }\n        ]\n      }\n    ]\n  }\n}"
            },
            "url": { "raw": "{{base_url}}/ValueSet", "host": ["{{base_url}}"], "path": ["ValueSet"] }
          }
        },
        {
          "name": "Update ValueSet (PUT)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/fhir+json" },
              { "key": "Accept",       "value": "application/fhir+json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"resourceType\": \"ValueSet\",\n  \"id\": \"{{vs_id}}\",\n  \"name\": \"Updated_ValueSet\",\n  \"title\": \"1 Min Apgar Score (NCHS) — Updated\",\n  \"status\": \"active\",\n  \"description\": \"Updated via Postman.\"\n}"
            },
            "url": { "raw": "{{base_url}}/ValueSet/{{vs_id}}", "host": ["{{base_url}}"], "path": ["ValueSet","{{vs_id}}"] }
          }
        },
        {
          "name": "Archive ValueSet",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": { "raw": "{{base_url}}/ValueSet/{{vs_id}}/$archive", "host": ["{{base_url}}"], "path": ["ValueSet","{{vs_id}}","$archive"] }
          }
        },
        {
          "name": "Restore ValueSet",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": { "raw": "{{base_url}}/ValueSet/{{vs_id}}/$archive?restore=true", "host": ["{{base_url}}"], "path": ["ValueSet","{{vs_id}}","$archive"], "query": [{ "key": "restore", "value": "true" }] }
          }
        },
        {
          "name": "Delete ValueSet",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{base_url}}/ValueSet/{{vs_id}}", "host": ["{{base_url}}"], "path": ["ValueSet","{{vs_id}}"] }
          }
        }
      ]
    },

    {
      "name": "03 · ValueSet — Operations",
      "description": "FHIR operations: $expand, $validate-code, $validate-batch, $concept-search, $views, $tag-view, $diff.",
      "item": [
        {
          "name": "$expand — by URL (GET)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/fhir+json" }],
            "url": {
              "raw": "{{base_url}}/ValueSet/$expand?url={{specimen_vs_url}}&count=50",
              "host": ["{{base_url}}"], "path": ["ValueSet","$expand"],
              "query": [
                { "key": "url",   "value": "{{specimen_vs_url}}" },
                { "key": "count", "value": "50" }
              ]
            }
          }
        },
        {
          "name": "$expand — by URL with filter (GET)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/fhir+json" }],
            "url": {
              "raw": "{{base_url}}/ValueSet/$expand?url={{specimen_vs_url}}&filter=blood&count=20",
              "host": ["{{base_url}}"], "path": ["ValueSet","$expand"],
              "query": [
                { "key": "url",    "value": "{{specimen_vs_url}}" },
                { "key": "filter", "value": "blood" },
                { "key": "count",  "value": "20" }
              ]
            }
          }
        },
        {
          "name": "$expand — SNOMED ECL descendants (GET)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/fhir+json" }],
            "url": {
              "raw": "{{base_url}}/ValueSet/$expand?url=http://snomed.info/sct?fhir_vs=isa/119297000&count=30",
              "host": ["{{base_url}}"], "path": ["ValueSet","$expand"],
              "query": [
                { "key": "url",   "value": "http://snomed.info/sct?fhir_vs=isa/119297000" },
                { "key": "count", "value": "30" }
              ]
            }
          }
        },
        {
          "name": "$expand — by ValueSet ID (GET)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/fhir+json" }],
            "url": {
              "raw": "{{base_url}}/ValueSet/{{vs_id}}/$expand",
              "host": ["{{base_url}}"], "path": ["ValueSet","{{vs_id}}","$expand"]
            }
          }
        },
        {
          "name": "$validate-code — valid code (GET)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/fhir+json" }],
            "url": {
              "raw": "{{base_url}}/ValueSet/$validate-code?url={{specimen_vs_url}}&system=http://snomed.info/sct&code=119297000",
              "host": ["{{base_url}}"], "path": ["ValueSet","$validate-code"],
              "query": [
                { "key": "url",    "value": "{{specimen_vs_url}}" },
                { "key": "system", "value": "http://snomed.info/sct" },
                { "key": "code",   "value": "119297000" }
              ]
            }
          }
        },
        {
          "name": "$validate-code — invalid code (GET)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/fhir+json" }],
            "url": {
              "raw": "{{base_url}}/ValueSet/$validate-code?url={{specimen_vs_url}}&system=http://snomed.info/sct&code=INVALID123",
              "host": ["{{base_url}}"], "path": ["ValueSet","$validate-code"],
              "query": [
                { "key": "url",    "value": "{{specimen_vs_url}}" },
                { "key": "system", "value": "http://snomed.info/sct" },
                { "key": "code",   "value": "INVALID123" }
              ]
            }
          }
        },
        {
          "name": "$validate-batch — mixed codes (POST)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept",       "value": "application/fhir+json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"url\": \"{{specimen_vs_url}}\",\n  \"items\": [\n    { \"code\": \"119297000\", \"system\": \"http://snomed.info/sct\" },\n    { \"code\": \"258450006\", \"system\": \"http://snomed.info/sct\" },\n    { \"code\": \"INVALID\",   \"system\": \"http://snomed.info/sct\" }\n  ]\n}"
            },
            "url": { "raw": "{{base_url}}/ValueSet/$validate-batch", "host": ["{{base_url}}"], "path": ["ValueSet","$validate-batch"] }
          }
        },
        {
          "name": "$validate-batch — HL7 v2 message codes (POST)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept",       "value": "application/fhir+json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    { \"code\": \"M\",       \"system\": \"http://terminology.hl7.org/CodeSystem/v2-0001\" },\n    { \"code\": \"94500-6\", \"system\": \"http://loinc.org\" },\n    { \"code\": \"U07.1\",   \"system\": \"http://hl7.org/fhir/sid/icd-10-cm\" }\n  ]\n}"
            },
            "url": { "raw": "{{base_url}}/ValueSet/$validate-batch", "host": ["{{base_url}}"], "path": ["ValueSet","$validate-batch"] }
          }
        },
        {
          "name": "$concept-search — by code",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/fhir+json" }],
            "url": {
              "raw": "{{base_url}}/ValueSet/$concept-search?q=119297000&limit=10",
              "host": ["{{base_url}}"], "path": ["ValueSet","$concept-search"],
              "query": [
                { "key": "q",     "value": "119297000" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "$concept-search — by display term",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/fhir+json" }],
            "url": {
              "raw": "{{base_url}}/ValueSet/$concept-search?q=blood+specimen&limit=20",
              "host": ["{{base_url}}"], "path": ["ValueSet","$concept-search"],
              "query": [
                { "key": "q",     "value": "blood specimen" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "$views — list disease/condition views",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/ValueSet/$views", "host": ["{{base_url}}"], "path": ["ValueSet","$views"] }
          }
        },
        {
          "name": "$tag-view — add view tag",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/ValueSet/$tag-view?resource_id={{vs_id}}&view_id=covid-19-case-notification",
              "host": ["{{base_url}}"], "path": ["ValueSet","$tag-view"],
              "query": [
                { "key": "resource_id", "value": "{{vs_id}}" },
                { "key": "view_id",     "value": "covid-19-case-notification" }
              ]
            }
          }
        },
        {
          "name": "$tag-view — remove view tag",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/ValueSet/$tag-view?resource_id={{vs_id}}&view_id=covid-19-case-notification",
              "host": ["{{base_url}}"], "path": ["ValueSet","$tag-view"],
              "query": [
                { "key": "resource_id", "value": "{{vs_id}}" },
                { "key": "view_id",     "value": "covid-19-case-notification" }
              ]
            }
          }
        },
        {
          "name": "$diff — compare two versions",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/ValueSet/{{vs_id}}/$diff?from_version=1&to_version=2",
              "host": ["{{base_url}}"], "path": ["ValueSet","{{vs_id}}","$diff"],
              "query": [
                { "key": "from_version", "value": "1" },
                { "key": "to_version",   "value": "2" }
              ]
            }
          }
        }
      ]
    },

    {
      "name": "04 · CodeSystem — CRUD",
      "description": "Create, read, update, delete CodeSystem resources.",
      "item": [
        {
          "name": "List CodeSystems (summary)",
