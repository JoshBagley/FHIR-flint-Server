              "mode": "raw",
              "raw": "{\n  \"resourceType\": \"CodeSystem\",\n  \"url\": \"http://snomed.info/sct\",\n  \"name\": \"SNOMEDCT\",\n  \"title\": \"SNOMED Clinical Terms\",\n  \"status\": \"active\",\n  \"content\": \"not-present\",\n  \"description\": \"Delegated to tx.fhir.org for $lookup and $expand.\"\n}"
            },
            "url": { "raw": "{{base_url}}/CodeSystem", "host": ["{{base_url}}"], "path": ["CodeSystem"] }
          }
        }
      ]
    },

    {
      "name": "05 · CodeSystem — Operations",
      "description": "$lookup and $subsumes operations.",
      "item": [
        {
          "name": "$lookup — SNOMED CT code",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/fhir+json" }],
            "url": {
              "raw": "{{base_url}}/CodeSystem/$lookup?system=http://snomed.info/sct&code=119297000",
              "host": ["{{base_url}}"], "path": ["CodeSystem","$lookup"],
              "query": [
                { "key": "system", "value": "http://snomed.info/sct" },
                { "key": "code",   "value": "119297000" }
              ]
            }
          }
        },
        {
          "name": "$lookup — LOINC code",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/fhir+json" }],
            "url": {
              "raw": "{{base_url}}/CodeSystem/$lookup?system=http://loinc.org&code=94500-6",
              "host": ["{{base_url}}"], "path": ["CodeSystem","$lookup"],
              "query": [
                { "key": "system", "value": "http://loinc.org" },
                { "key": "code",   "value": "94500-6" }
              ]
            }
          }
        },
        {
          "name": "$lookup — ICD-10-CM code",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/fhir+json" }],
            "url": {
              "raw": "{{base_url}}/CodeSystem/$lookup?system=http://hl7.org/fhir/sid/icd-10-cm&code=U07.1",
              "host": ["{{base_url}}"], "path": ["CodeSystem","$lookup"],
              "query": [
                { "key": "system", "value": "http://hl7.org/fhir/sid/icd-10-cm" },
                { "key": "code",   "value": "U07.1" }
              ]
            }
          }
        },
        {
          "name": "$lookup — RxNorm code",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/fhir+json" }],
            "url": {
              "raw": "{{base_url}}/CodeSystem/$lookup?system=http://www.nlm.nih.gov/research/umls/rxnorm&code=1049502",
              "host": ["{{base_url}}"], "path": ["CodeSystem","$lookup"],
              "query": [
                { "key": "system", "value": "http://www.nlm.nih.gov/research/umls/rxnorm" },
                { "key": "code",   "value": "1049502" }
              ]
            }
          }
        },
        {
          "name": "$lookup — CVX vaccine code",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/fhir+json" }],
            "url": {
              "raw": "{{base_url}}/CodeSystem/$lookup?system=http://hl7.org/fhir/sid/cvx&code=207",
              "host": ["{{base_url}}"], "path": ["CodeSystem","$lookup"],
              "query": [
                { "key": "system", "value": "http://hl7.org/fhir/sid/cvx" },
                { "key": "code",   "value": "207" }
              ]
            }
          }
        },
        {
          "name": "$lookup — HL7 v2 table code",
          "request": {
